{
  "name": "nos-addon-devkit",
  "version": "1.0.0",
  "description": "MCP server for Nebula on the Ship addon development",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js",
    "dev": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --watch",
    "start": "node dist/index.js",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.8.0"
  }
}
